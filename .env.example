# MikroMCP environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Transport: stdio (default) or http
MIKROMCP_TRANSPORT=stdio

# HTTP transport port (only used when MIKROMCP_TRANSPORT=http)
MIKROMCP_PORT=3000

# HTTP transport bind host — keep 127.0.0.1 unless you know what you're doing
MIKROMCP_BIND_HOST=127.0.0.1

# Path to routers config file
MIKROMCP_CONFIG_PATH=config/routers.yaml

# Path to identities config file (required for HTTP transport)
MIKROMCP_IDENTITIES_PATH=config/identities.yaml

# HMAC secret for destructive-action confirmation tokens (required in HTTP mode)
MIKROMCP_CONFIRMATION_SECRET=

# Log level: trace | debug | info | warn | error
MIKROMCP_LOG_LEVEL=info

# Path to write NDJSON audit log (omit to disable)
MIKROMCP_AUDIT_LOG_PATH=

# Named identity for stdio transport (omit to use built-in superadmin)
MIKROMCP_STDIO_IDENTITY=

# Router credentials — repeat for each router using its envPrefix from routers.yaml
# Example: for a router with envPrefix: ROUTER_CORE01
ROUTER_CORE01_USER=
ROUTER_CORE01_PASS=

# SSH settings (milliseconds)
MIKROMCP_SSH_COMMAND_TIMEOUT_MS=30000
MIKROMCP_SSH_MAX_OUTPUT_BYTES=524288

# HTTP rate limiting (requests per minute per IP, 0 = disabled)
MIKROMCP_HTTP_RATE_LIMIT_RPM=60

# HTTP max request body size in bytes
MIKROMCP_HTTP_MAX_BODY_BYTES=1048576
