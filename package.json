{
  "name": "mikrotik-mcp-server",
  "version": "0.1.0",
  "description": "Production-grade MCP server for MikroTik RouterOS",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "mikrotik-mcp-server": "dist/main.js"
  },
  "scripts": {
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "mikrotik",
    "routeros",
    "mcp",
    "model-context-protocol",
    "network-management"
  ],
  "author": "Ali Karami",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "nanoid": "^5.0.0",
    "pino": "^9.0.0",
    "ssh2": "^1.17.0",
    "undici": "^7.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ssh2": "^1.15.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "msw": "^2.0.0",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
