{
  "name": "mikromcp",
  "version": "1.0.10",
  "mcpName": "io.github.AliKarami/mikromcp",
  "description": "Production-grade MCP server for MikroTik RouterOS",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "mikromcp": "dist/main.js"
  },
  "files": [
    "dist/main.js",
    "config/routers.example.yaml",
    "config/identities.example.yaml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run && tsc --noEmit && eslint src/",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "package:binaries": "pkg dist/main.js --targets node22-linux-x64,node22-linux-arm64,node22-macos-x64,node22-macos-arm64,node22-win-x64 --out-path ./binaries"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "mikrotik",
    "routeros",
    "mcp",
    "model-context-protocol",
    "network-management"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AliKarami/MikroMCP.git"
  },
  "author": "Ali Karami",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "basic-ftp": "^6.0.1",
    "bcryptjs": "^3.0.3",
    "chalk": "^5.6.2",
    "commander": "^8.3.0",
    "dotenv": "^17.4.2",
    "nanoid": "^5.0.0",
    "pino": "^9.0.0",
    "ssh2": "^1.17.0",
    "undici": "^7.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/ssh2": "^1.15.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@yao-pkg/pkg": "^5.0.0",
    "eslint": "^9.0.0",
    "msw": "^2.0.0",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
